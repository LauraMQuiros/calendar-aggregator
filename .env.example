# Database (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///./calendar_aggregator.db

# --- Local models (no API keys needed) ---
# Ollama: install from https://ollama.com, then: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Hugging Face transformers (downloads ~1-3GB on first run)
# USE_TRANSFORMERS=1
# TRANSFORMERS_MODEL=Qwen/Qwen2-1.5B-Instruct

# --- Cloud APIs (fallback) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

{
  "name": "calendar-aggregator",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "python -m backend.main",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "npm run build --prefix frontend",
    "install:frontend": "npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
